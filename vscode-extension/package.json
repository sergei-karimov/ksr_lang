{
  "name": "ksr-lang",
  "displayName": "KSR Language",
  "description": "Syntax highlighting and error reporting for the KSR language",
  "version": "0.1.0",
  "publisher": "ksr",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ksr",
        "aliases": [
          "KSR",
          "ksr"
        ],
        "extensions": [
          ".ksr"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ksr",
        "scopeName": "source.ksr",
        "path": "./syntaxes/ksr.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "KSR",
      "properties": {
        "ksr.executablePath": {
          "type": "string",
          "default": "ksr",
          "description": "Path to the ksr executable used to start the Language Server. Defaults to 'ksr' (must be on PATH)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run bundle -- --watch",
    "vscode:prepublish": "npm run bundle -- --minify",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.0"
  }
}
