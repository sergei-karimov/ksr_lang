{
  "name": "ksr-lang",
  "displayName": "KSR Language",
  "description": "Syntax highlighting and error reporting for the KSR language",
  "version": "0.1.0",
  "publisher": "ksr",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:ksr",
    "onDebugInitialConfigurations:ksr"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ksr",
        "aliases": [
          "KSR",
          "ksr"
        ],
        "extensions": [
          ".ksr"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ksr",
        "scopeName": "source.ksr",
        "path": "./syntaxes/ksr.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "KSR",
      "properties": {
        "ksr.executablePath": {
          "type": "string",
          "default": "ksr",
          "description": "Path to the ksr executable used to start the Language Server. Defaults to 'ksr' (must be on PATH)."
        }
      }
    },
    "breakpoints": [
      { "language": "ksr" }
    ],
    "debuggers": [
      {
        "type": "ksr",
        "label": "KSR",
        "languages": ["ksr"],
        "configurationSnippets": [
          {
            "label": "KSR: Launch",
            "description": "Launch and debug a KSR project (requires C# extension)",
            "body": {
              "name": "Debug KSR",
              "type": "ksr",
              "request": "launch",
              "preLaunchTask": "build",
              "program": "^\"\\${workspaceFolder}/bin/Debug/net8.0/\\${workspaceFolderBasename}.dll\"",
              "args": [],
              "cwd": "^\"\\${workspaceFolder}\"",
              "console": "internalConsole",
              "stopAtEntry": false
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run bundle -- --watch",
    "vscode:prepublish": "npm run bundle -- --minify",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.0"
  }
}
