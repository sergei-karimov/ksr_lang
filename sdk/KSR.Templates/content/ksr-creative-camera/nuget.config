<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      During development (before KSR packages are on nuget.org):
      Run the KSR installer or add a local source that points to the repo artifacts folder,
      e.g.  dotnet nuget add source C:\dev\ksr_lang\artifacts -n ksr-local
    -->

    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
