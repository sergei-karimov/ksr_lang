<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      During development (before KSR.Sdk is on nuget.org):
      Replace the path below with the absolute path to your local KSR artifacts folder,
      e.g.  C:\dev\ksr_lang\artifacts\
      Then run: dotnet restore
    -->
    <!-- <add key="local-ksr" value="C:\path\to\ksr_lang\artifacts\" /> -->

    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
