<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>

    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>$(NoWarn);8981</NoWarn>

    <PackageId>KSR.Creative</PackageId>
    <Version>0.1.0</Version>
    <Authors>KSR Authors</Authors>
    <Description>KSR creative-coding runtime: minimal Raylib window, draw loop, and VideoFrame rendering.</Description>
    <PackageTags>ksr;creative-coding;raylib;graphics</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\KSR.Vision\KSR.Vision.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Raylib-cs" Version="7.0.2" />
  </ItemGroup>

</Project>
