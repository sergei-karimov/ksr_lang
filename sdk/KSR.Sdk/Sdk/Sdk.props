<Project>

  <!--
    KSR SDK — props side.
    Imported BEFORE the project file.

    We delegate to Microsoft.NET.Sdk for all standard .NET machinery
    (TFM resolution, NuGet, Roslyn, etc.).  We then layer KSR.Build on top.
  -->

  <!-- Bootstrap the standard .NET SDK props -->
  <Import Project="Sdk.props" Sdk="Microsoft.NET.Sdk" />

  <PropertyGroup>
    <!-- KSR projects are executables by default (override in the project if needed) -->
    <OutputType Condition="'$(OutputType)' == ''">Exe</OutputType>
    <TargetFramework Condition="'$(TargetFramework)' == ''">net8.0</TargetFramework>
    <Nullable Condition="'$(Nullable)' == ''">enable</Nullable>
    <ImplicitUsings Condition="'$(ImplicitUsings)' == ''">enable</ImplicitUsings>

    <!--
      KSR projects don't have hand-written C# files, so disable the default
      C# glob.  Only the .g.cs generated by KsrCompileTask should be compiled.
    -->
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <!--
    Pull in KSR.Build (the task package) and KSR.StdLib (the standard library).
    Versions are pinned here so end users never have to specify them.
  -->
  <ItemGroup>
    <PackageReference Include="KSR.Build"   Version="0.1.0" PrivateAssets="all" />
    <PackageReference Include="KSR.StdLib"  Version="0.1.0" />
  </ItemGroup>

</Project>
